# Modo recomendado para Streamlit Community Cloud gratis:
APP_STORAGE_MODE = "none"

# Si luego corres la app en tu propia PC o servidor y quieres historial local:
# APP_STORAGE_MODE = "sqlite"
# APP_SQLITE_PATH = "data/app_runs.db"

# Si mas adelante migras a una base de datos en hosting, mantendremos esta
# misma idea de "backend" y solo cambiaremos la implementacion.

# Modo recomendado para Streamlit Community Cloud gratis:
APP_STORAGE_MODE = "none"

# Si luego corres la app en tu propia PC o servidor y quieres historial local:
# APP_STORAGE_MODE = "sqlite"
# APP_SQLITE_PATH = "data/app_runs.db"

# Si quieres login, roles y gestion de usuarios, usa MySQL:
# APP_STORAGE_MODE = "mysql"
# APP_MYSQL_HOST = "127.0.0.1"
# APP_MYSQL_PORT = 3306
# APP_MYSQL_DATABASE = "tec_norvial"
# APP_MYSQL_USER = "tu_usuario"
# APP_MYSQL_PASSWORD = "tu_password"
# APP_MYSQL_CHARSET = "utf8mb4"
# APP_MYSQL_CONNECT_TIMEOUT = 10
# APP_MYSQL_SSL_DISABLED = false
# APP_MYSQL_SSL_VERIFY_CERT = false
# APP_MYSQL_SSL_VERIFY_IDENTITY = false
# APP_MYSQL_SSL_CA = ""
# APP_MYSQL_SSL_CERT = ""
# APP_MYSQL_SSL_KEY = ""
